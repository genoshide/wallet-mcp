# wallet-mcp Environment Configuration
# Copy this file to .env and fill in values

# ── RPC Endpoints ──────────────────────────────────────────────────────────
# Solana — default uses mainnet public RPC (may rate-limit on heavy use)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# EVM — default uses public infura (no key needed for basic use)
EVM_RPC_URL=https://mainnet.infura.io/v3/9aa3d95b3bc440fa88ea12eaa4456161

# Custom per-chain RPC (optional, overrides above)
# BSC_RPC_URL=https://bsc-dataseed.binance.org/
# POLYGON_RPC_URL=https://polygon-rpc.com
# ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# ── Storage ────────────────────────────────────────────────────────────────
# Leave empty to use default ~/.wallet-mcp/wallets.csv
# WALLET_DATA_DIR=/custom/path/to/data

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# LOG_FILE=~/.wallet-mcp/wallet-mcp.log
